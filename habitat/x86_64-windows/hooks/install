# Removes outdated gems bundled with the Ruby Habitat package and installs updated versions.

$pkg_prefix  = hab pkg path chef/inspec
$rubyPkgPath = hab pkg path chef/ruby31-plus-devkit

# Set GEM_HOME and GEM_PATH to install gems into the package directory
$env:GEM_HOME = "$pkg_prefix\vendor"
$env:GEM_PATH = $env:GEM_HOME

# Gems whose Gemfile.lock should be removed (not needed at runtime)
$gemfileLockGems = @("lint_roller", "rbs")

# Gems to replace with updated versions: name = minimum version
$gemsToUpdate = @{
    "rexml" = "3.4.4"
    "zlib"  = "3.0.1"
    "erb"   = "4.0.3.1"
}

# Search both package roots recursively to find gems wherever they are installed
$searchRoots = @($rubyPkgPath, $pkg_prefix)

Write-Host "=== InSpec Install Hook: Cleaning up bundled gems ==="

# Remove Gemfile.lock from specified gems
foreach ($gem in $gemfileLockGems) {
    Write-Host "Removing Gemfile.lock files from $gem gems..."
    $escapedGem = [regex]::Escape($gem)

    foreach ($root in $searchRoots) {
        Get-ChildItem $root -Recurse -Filter "Gemfile.lock" -ErrorAction SilentlyContinue |
            Where-Object { $_.DirectoryName -match "\\gems\\$escapedGem-" } |
            ForEach-Object {
                Write-Host "  Removing: $($_.FullName)"
                Remove-Item $_.FullName -Force -ErrorAction SilentlyContinue
            }
    }
}

# Remove old gem versions and install updated ones
foreach ($entry in $gemsToUpdate.GetEnumerator()) {
    $gemName     = $entry.Key
    $gemVersion  = $entry.Value
    $escapedName = [regex]::Escape($gemName)
    Write-Host "Processing $gemName (target version: $gemVersion)..."

    foreach ($root in $searchRoots) {
        Get-ChildItem $root -Recurse -Filter "$gemName-*.gemspec" -ErrorAction SilentlyContinue |
            Where-Object {
                # Match gemspecs in both "specifications/" (regular gems) and
                # "specifications/default/" (Ruby default/bundled gems)
                $_.Directory.Name -eq "specifications" -or
                ($_.Directory.Name -eq "default" -and $_.Directory.Parent.Name -eq "specifications")
            } |
            ForEach-Object {
                $installedVersion = $_.BaseName -replace "^$escapedName-", ""
                try {
                    if ([version]$installedVersion -lt [version]$gemVersion) {
                        Write-Host "  Removing old version: $gemName-$installedVersion"
                        Remove-Item $_.FullName -Force -ErrorAction SilentlyContinue

                        # For default gems the spec is one level deeper, so the gem root
                        # (sibling of "specifications/") differs accordingly.
                        $gemRoot = if ($_.Directory.Name -eq "default") {
                            $_.Directory.Parent.Parent.FullName
                        } else {
                            $_.Directory.Parent.FullName
                        }
                        $gemDir = Join-Path $gemRoot "gems\$gemName-$installedVersion"
                        if (Test-Path $gemDir) {
                            Write-Host "    Removing directory: $gemDir"
                            Remove-Item $gemDir -Recurse -Force -ErrorAction SilentlyContinue
                        }
                    } else {
                        Write-Host "  Keeping version: $gemName-$installedVersion (>= $gemVersion)"
                    }
                } catch {
                    Write-Host "  Warning: Could not parse version for $gemName-$installedVersion"
                }
            }
    }

    # Check only our vendor directory — avoids false positives from Ruby default
    # gems that appear in "gem list --local" but are not actually in our package.
    $installedGem = Get-ChildItem "$pkg_prefix\vendor\specifications" -Filter "$gemName-*.gemspec" -ErrorAction SilentlyContinue |
        Where-Object {
            $ver = $_.BaseName -replace "^$escapedName-", ""
            try { [version]$ver -ge [version]$gemVersion } catch { $false }
        } | Select-Object -First 1

    if (-not $installedGem) {
        Write-Host "Installing $gemName $gemVersion..."
        gem install $gemName -v $gemVersion --no-document
    } else {
        Write-Host "$gemName $gemVersion or newer already installed"
    }
}

Write-Host "=== Install hook completed ==="
