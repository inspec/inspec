#!/bin/sh
# Removes outdated gems bundled with the Ruby Habitat package and installs updated versions.

# Set GEM_HOME and GEM_PATH to install gems into the package directory
export GEM_HOME="$pkg_prefix/lib"
export GEM_PATH="$GEM_HOME"

RUBY_GEMS_PATH="$(hab pkg path core/ruby31)/lib/ruby/gems"

# Gems whose Gemfile.lock should be removed (not used at runtime)
GEMFILE_LOCK_GEMS="lint_roller rbs"

# Gems to replace with updated versions: "name:version"
GEMS_TO_UPDATE="rexml:3.4.4"

for gem in $GEMFILE_LOCK_GEMS; do
  find "$pkg_prefix/lib/gems" "$RUBY_GEMS_PATH" \
    -path "*/gems/${gem}-*/Gemfile.lock" -delete 2>/dev/null || true
done

for entry in $GEMS_TO_UPDATE; do
  gem_name="${entry%%:*}"
  gem_version="${entry##*:}"

  # Find all gemspecs for this gem and check versions
  find "$RUBY_GEMS_PATH" -name "${gem_name}-*.gemspec" 2>/dev/null | while read -r gemspec; do
    # Extract version from filename (e.g., rexml-3.3.9.gemspec -> 3.3.9)
    installed_version=$(basename "$gemspec" .gemspec | sed "s/^${gem_name}-//")
    
    # Compare versions: remove if installed < required
    if [ "$(printf '%s\n' "$gem_version" "$installed_version" | sort -V | head -n1)" != "$gem_version" ]; then
      # installed_version < gem_version, so remove it
      rm -f "$gemspec" 2>/dev/null || true
      
      # Also remove the gem directory
      gem_dir="$RUBY_GEMS_PATH/../../gems/${gem_name}-${installed_version}"
      [ -d "$gem_dir" ] && rm -rf "$gem_dir" 2>/dev/null || true
    fi
  done

  # Install the required version if not already present
  if ! gem list -i "^${gem_name}$" -v ">= ${gem_version}" >/dev/null 2>&1; then
    gem install "${gem_name}" -v "${gem_version}" --no-document
  fi
done
