#!/bin/sh
# Removes outdated gems bundled with the Ruby Habitat package and installs updated versions.

pkg_prefix="$(hab pkg path chef/inspec)"
ruby_pkg_path="$(hab pkg path core/ruby31)"

# Set GEM_HOME and GEM_PATH to install gems into the package directory
export GEM_HOME="$pkg_prefix/lib"
export GEM_PATH="$GEM_HOME"

# Gems whose Gemfile.lock should be removed (not needed at runtime)
GEMFILE_LOCK_GEMS="lint_roller rbs"

# Gems to replace with updated versions: "name:version"
GEMS_TO_UPDATE="rexml:3.4.4 resolv:0.2.3"

# Search both package roots recursively to find gems wherever they are installed
SEARCH_ROOTS="$ruby_pkg_path $pkg_prefix"

echo "=== InSpec Install Hook: Cleaning up bundled gems ==="

# Remove Gemfile.lock from specified gems
for gem in $GEMFILE_LOCK_GEMS; do
  echo "Removing Gemfile.lock files from ${gem} gems..."

  for root in $SEARCH_ROOTS; do
    find "$root" -type f -name "Gemfile.lock" 2>/dev/null | \
      grep "/gems/${gem}-" | \
      while read -r lockfile; do
        echo "  Removing: $lockfile"
        rm -f "$lockfile" 2>/dev/null || true
      done
  done
done

# Remove old gem versions and install updated ones
for entry in $GEMS_TO_UPDATE; do
  gem_name="${entry%%:*}"
  gem_version="${entry##*:}"

  echo "Processing ${gem_name} (target version: ${gem_version})..."

  for root in $SEARCH_ROOTS; do
    find "$root" -type f -name "${gem_name}-*.gemspec" 2>/dev/null | \
      grep "/specifications/" | \
      while read -r gemspec; do
        installed_version=$(basename "$gemspec" .gemspec | sed "s/^${gem_name}-//")

        # Compare versions: remove if installed < required
        if [ "$(printf '%s\n' "$gem_version" "$installed_version" | sort -V | head -n1)" != "$gem_version" ]; then
          echo "  Removing old version: ${gem_name}-${installed_version}"
          rm -f "$gemspec" 2>/dev/null || true

          spec_dir=$(dirname "$gemspec")
          gem_dir=$(dirname "$spec_dir")/gems/${gem_name}-${installed_version}
          if [ -d "$gem_dir" ]; then
            echo "    Removing directory: $gem_dir"
            rm -rf "$gem_dir" 2>/dev/null || true
          fi
        else
          echo "  Keeping version: ${gem_name}-${installed_version} (>= ${gem_version})"
        fi
      done
  done

  # Install the required version if not already present
  if ! gem list -i "^${gem_name}$" -v ">= ${gem_version}" >/dev/null 2>&1; then
    echo "Installing ${gem_name} ${gem_version}..."
    gem install "${gem_name}" -v "${gem_version}" --no-document
  else
    echo "${gem_name} ${gem_version} or newer already installed"
  fi
done

echo "=== Install hook completed ==="
